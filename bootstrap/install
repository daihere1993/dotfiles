#!/bin/sh
set -eu

if [ "$(uname -s)" != "Darwin" ] || [ "$(uname -m)" != "arm64" ]; then
  echo "bootstrap requires Apple Silicon macOS" >&2
  exit 2
fi

if ! xcode-select -p >/dev/null 2>&1; then
  echo "Xcode Command Line Tools are required. Run: xcode-select --install" >&2
  exit 2
fi

if ! command -v nix >/dev/null 2>&1 \
  && [ -e /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
  # shellcheck disable=SC1091
  . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
fi

if ! command -v nix >/dev/null 2>&1; then
  echo "Nix is not installed. Installing multi-user Nix from nixos.org..." >&2
  installer=$(mktemp -t dotfiles-nix-install.XXXXXX)
  trap 'rm -f "$installer"' EXIT HUP INT TERM
  curl --fail --location --proto '=https' --tlsv1.2 \
    --output "$installer" https://nixos.org/nix/install
  sh "$installer" --daemon --yes
  rm -f "$installer"
  trap - EXIT HUP INT TERM
  if [ -e /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
    # shellcheck disable=SC1091
    . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
  fi
fi

if [ -n "${NIX_CONFIG:-}" ]; then
  NIX_CONFIG="$NIX_CONFIG
experimental-features = nix-command flakes"
else
  NIX_CONFIG='experimental-features = nix-command flakes'
fi
export NIX_CONFIG

./bootstrap/install-dot
dot_cli=$HOME/.local/bin/dot

"$dot_cli" init
"$dot_cli" validate
"$dot_cli" apply --check
"$dot_cli" apply
"$dot_cli" doctor

case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) echo "Add $HOME/.local/bin to PATH to run dot directly." >&2 ;;
esac

echo "Bootstrap complete. Agent vendor and GitHub authentication remain manual."
