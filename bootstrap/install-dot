#!/bin/sh
set -eu

script_directory=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
repository=$(dirname -- "$script_directory")
dotfiles_state_root=$HOME/.local/state/dotfiles
state_root=$dotfiles_state_root/cli
profile=$state_root/profile
dev_dot=$state_root/bin/dot
bin_directory=$HOME/.local/bin
entry=$bin_directory/dot
expected=$profile/bin/dot
required_modules="apply_events apply_flow apply_reporter"

if [ -L "$dotfiles_state_root" ]; then
  echo "dotfiles state root must not be a symlink: $dotfiles_state_root" >&2
  exit 3
fi
if [ -e "$dotfiles_state_root" ] && [ ! -d "$dotfiles_state_root" ]; then
  echo "dotfiles state root must be a directory: $dotfiles_state_root" >&2
  exit 3
fi
mkdir -p "$dotfiles_state_root"

owner=$(/usr/bin/stat -f '%u' "$dotfiles_state_root")
if [ "$owner" != "$(id -u)" ]; then
  echo "dotfiles state root is not owned by the current user: $dotfiles_state_root" >&2
  exit 3
fi
chmod 0700 "$dotfiles_state_root"

if [ -L "$state_root" ]; then
  echo "dot CLI state root must not be a symlink: $state_root" >&2
  exit 3
fi
mkdir -p "$state_root"
chmod 0700 "$state_root"

owner=$(/usr/bin/stat -f '%u' "$state_root")
if [ "$owner" != "$(id -u)" ]; then
  echo "dot CLI state root is not owned by the current user: $state_root" >&2
  exit 3
fi

if ! command -v nix >/dev/null 2>&1 \
  && [ -e /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
  # shellcheck disable=SC1091
  . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
fi

if ! command -v nix >/dev/null 2>&1; then
  echo "Nix is not available in PATH." >&2
  echo "If Nix is installed, run:" >&2
  echo "  . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh" >&2
  echo "Or run the full bootstrap installer: ./bootstrap/install" >&2
  exit 2
fi

if [ -n "${NIX_CONFIG:-}" ]; then
  NIX_CONFIG="$NIX_CONFIG
experimental-features = nix-command flakes"
else
  NIX_CONFIG='experimental-features = nix-command flakes'
fi
export NIX_CONFIG

needs_dev_install=false
for module in $required_modules; do
  rel="cli/dotfiles_cli/${module}.py"
  if [ ! -f "$repository/$rel" ]; then
    echo "missing required module source: $rel" >&2
    exit 2
  fi
done

if git -C "$repository" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  for module in $required_modules; do
    rel="cli/dotfiles_cli/${module}.py"
    if ! git -C "$repository" ls-files --error-unmatch "$rel" >/dev/null 2>&1; then
      needs_dev_install=true
      break
    fi
  done
else
  needs_dev_install=true
fi

cd "$repository"

if [ "$needs_dev_install" = true ]; then
  python=$(command -v python3.13 || command -v python3.12 || command -v python3.11 || command -v python3)
  if [ -z "$python" ]; then
    echo "python3 is required to install dot from an uncommitted working tree" >&2
    exit 2
  fi
  mkdir -p "$state_root/bin"
  nix_bin=$(command -v nix)
  cat > "$dev_dot" <<EOF
#!/usr/bin/env bash
set -euo pipefail
repo='$repository'
export PYTHONPATH="\$repo/cli\${PYTHONPATH:+:\$PYTHONPATH}"
export PATH="${nix_bin%/*}:\$PATH"
if [ -n "\${NIX_CONFIG:-}" ]; then
  export NIX_CONFIG="\$NIX_CONFIG
experimental-features = nix-command flakes"
else
  export NIX_CONFIG='experimental-features = nix-command flakes'
fi
exec '$python' -m dotfiles_cli "\$@"
EOF
  chmod +x "$dev_dot"
  install_target=$dev_dot
  echo "Installing dot from working tree (dev mode: untracked CLI modules are not in the Nix build input)." >&2
  echo "Run 'git add cli/dotfiles_cli/apply_*.py' and re-run this script for a Nix-packaged install." >&2
else
  store=$(nix --extra-experimental-features 'nix-command flakes' \
    build --no-link --print-out-paths .#dot)
  if [ -z "$store" ] || [ "$(printf '%s\n' "$store" | wc -l | tr -d ' ')" != 1 ]; then
    echo "dot package build returned an unexpected Store path" >&2
    exit 4
  fi

  nix-env --profile "$profile" --set "$store"
  if [ ! -x "$expected" ]; then
    echo "dot package does not contain an executable at $expected" >&2
    exit 4
  fi

  python_site=$(
    find "$profile/lib" -maxdepth 2 -type d -name 'site-packages' 2>/dev/null | head -n 1
  )
  if [ -z "$python_site" ]; then
    echo "could not locate Python site-packages in $profile" >&2
    exit 4
  fi
  for module in $required_modules; do
    if [ ! -f "$python_site/dotfiles_cli/${module}.py" ]; then
      echo "dot package is missing dotfiles_cli.${module}" >&2
      echo "Rebuild after ensuring cli/dotfiles_cli/${module}.py is tracked by git." >&2
      exit 4
    fi
  done
  install_target=$expected
fi

mkdir -p "$bin_directory"
if [ -L "$entry" ]; then
  current_target=$(readlink "$entry")
  case "$current_target" in
    "$expected"|"$dev_dot"|"$state_root"/*|"$profile"/*)
      ln -sf "$install_target" "$entry"
      ;;
    *)
      echo "refusing to replace existing dot symlink: $entry" >&2
      exit 3
      ;;
  esac
elif [ -e "$entry" ]; then
  echo "refusing to replace existing dot entry: $entry" >&2
  exit 3
else
  ln -s "$install_target" "$entry"
fi

"$entry" --version
echo "dot CLI installed: $entry -> $install_target"
